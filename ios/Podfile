platform :ios, '13.0'

# Locate Flutter SDK and load CocoaPods helper (robust to CI layouts)
def load_flutter_podhelper
  # Prefer environment variable if present
  flutter_root = ENV['FLUTTER_ROOT']
  if flutter_root.nil? || flutter_root.empty?
    generated = File.join(__dir__, 'Flutter', 'Generated.xcconfig')
    if File.exist?(generated)
      match = File.read(generated).match(/FLUTTER_ROOT=(.*)/)
      flutter_root = match && match[1]
    end
  end

  if flutter_root && !flutter_root.empty?
    sdk_helper = File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))
    if File.exist?(sdk_helper)
      require sdk_helper
      return true
    end
  end

  # Fallback to project-local helper generated by Flutter
  local_helper = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __dir__)
  if File.exist?(local_helper)
    require local_helper
    return true
  end

  raise "Unable to locate Flutter podhelper.rb. Checked SDK path '#{flutter_root}' and '#{local_helper}'."
end

load_flutter_podhelper
flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  flutter_additional_ios_build_settings(installer)
end
