platform :ios, '13.0'

# Make CocoaPods behavior more stable in CI
ENV['COCOAPODS_NO_STATS'] = 'true'
install! 'cocoapods', :generate_multiple_pod_projects => true, :incremental_installation => true

# Locate Flutter SDK and load CocoaPods helper (robust to CI layouts)
def load_flutter_podhelper
  # 1) Prefer FLUTTER_ROOT if provided
  flutter_root = ENV['FLUTTER_ROOT']

  # 2) Otherwise, derive from the flutter binary on PATH (Codemagic)
  if flutter_root.nil? || flutter_root.empty?
    flutter_bin = `which flutter`.strip
    if !flutter_bin.empty? && File.exist?(flutter_bin)
      # Resolve symlinks (e.g. /usr/local/bin/flutter) and go up two levels to SDK root
      resolved_bin = File.realpath(flutter_bin)
      flutter_root = File.expand_path(File.join(resolved_bin, '..', '..'))
    end
  end

  # 3) Try SDK helper
  if flutter_root && !flutter_root.empty?
    sdk_helper = File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))
    if File.exist?(sdk_helper)
      require sdk_helper
      return true
    end
  end

  # 4) Fallback to project-local helper, if generated
  local_helper = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __dir__)
  if File.exist?(local_helper)
    require local_helper
    return true
  end

  raise "Unable to locate Flutter podhelper.rb. Checked SDK path '#{flutter_root}' and '#{local_helper}'. Ensure Flutter is installed and on PATH."
end

load_flutter_podhelper
flutter_ios_podfile_setup

target 'Runner' do
  # Use static frameworks to avoid dynamic linking issues in CI (Codemagic)
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  flutter_additional_ios_build_settings(installer)

  # Enforce minimum iOS deployment target for all pods
  begin
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
    end
  rescue => e
    puts "[Podfile post_install] Warning: failed to adjust deployment targets: #{e}"
  end
end
